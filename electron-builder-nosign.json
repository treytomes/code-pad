{
  "extends": null,
  "appId": "com.codepad.app",
  "productName": "CodePad",
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "directories": {
    "buildResources": "assets",
    "output": "release"
  },
  "extraFiles": [],
  "win": {
    "target": [
      {
        "target": "zip",
        "arch": ["x64"]
      }
    ],
    "icon": "assets/icon.ico",
    "forceCodeSigning": false
  },
  "mac": {
    "target": "dmg",
    "icon": "assets/icon.icns",
    "category": "public.app-category.developer-tools"
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "icon": "assets/icon.png",
    "category": "Development"
  }
}
